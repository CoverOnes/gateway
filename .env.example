# CoverOnes Gateway — environment template
# Copy to .env for local development. Never commit the real .env.
# Production: set these as environment variables (Railway secrets / k8s Secrets).

# ── Server ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_ENV=development
GATEWAY_LOG_LEVEL=INFO

# ── JWKS / JWT ──────────────────────────────────────────────────────────────
# Full URL of the user service /jwks endpoint.
USER_JWKS_URL=REPLACE_ME

# JWKS cache TTL in seconds (default 300, aligned to user /jwks max-age).
GATEWAY_JWKS_CACHE_TTL_SEC=300

# Per-fetch HTTP client timeout in seconds (default 5).
GATEWAY_JWKS_FETCH_TIMEOUT_SEC=5

# Expected iss claim (default coverones-user).
GATEWAY_JWT_ISSUER=coverones-user

# Expected aud claim (default coverones).
GATEWAY_JWT_AUDIENCE=coverones

# Clock-skew leeway for exp/iat validation in seconds (default 60).
GATEWAY_JWT_LEEWAY_SEC=60

# ── Upstreams ────────────────────────────────────────────────────────────────
# Base URL of the user service (for /api/user/* and auth passthrough).
USER_UPSTREAM_URL=REPLACE_ME

# Optional comma-separated svc=url pairs for additional services.
# Example: GATEWAY_UPSTREAMS=project=http://project:8080,contract=http://contract:8080
GATEWAY_UPSTREAMS=

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Per-IP request budget per minute (default 60).
GATEWAY_RATE_LIMIT_PER_MIN=60

# Tighter budget for public /v1/auth/* routes (default 20).
GATEWAY_AUTH_RATE_LIMIT_PER_MIN=20

# ── Proxy ────────────────────────────────────────────────────────────────────
# Upstream response timeout for ReverseProxy transport in seconds (default 30).
GATEWAY_PROXY_TIMEOUT_SEC=30
